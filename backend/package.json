{
  "name": "seebeauty-backend",
  "version": "0.1.0",
  "description": "SeeBeauty AI Photo Rating Backend",
  "main": "src/app.js",
  "type": "module",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "jest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "db:init": "node src/scripts/initDatabase.js",
    "db:reset": "node src/scripts/initDatabase.js --force",
    "db:seed": "node src/scripts/initDatabase.js --seed",
    "db:repair-indexes": "node src/scripts/repairUserIndexes.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.540.0",
    "axios": "^1.12.2",
    "bcrypt": "^5.1.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "https-proxy-agent": "^7.0.6",
    "jsonrepair": "^3.13.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^3.0.1",
    "mysql2": "^3.9.1",
    "openai": "^4.28.4",
    "redis": "^4.6.13",
    "sequelize": "^6.36.0",
    "sharp": "^0.33.2",
    "stripe": "^19.2.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.19",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.3",
    "supertest": "^6.3.4",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
